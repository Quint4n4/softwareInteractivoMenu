# Copia este archivo a .env y ajusta los valores
DJANGO_SECRET_KEY=cambia-esto-por-uno-seguro
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
BASE_DOMAIN=localhost

# Base de datos: sqlite (dev) o postgres (prod)
DB_ENGINE=sqlite
# Para postgres descomenta y llena:
# DB_ENGINE=postgres
# DB_NAME=vitrina
# DB_USER=vitrina
# DB_PASSWORD=secret
# DB_HOST=localhost
# DB_PORT=5432
